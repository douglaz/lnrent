#!/usr/bin/env bash
# DO VPS destroy hook (lnrent recipes/do-vps). SPEC §7.2.
# Deletes the droplet for this subscription. IDEMPOTENT: a missing droplet (404) is success, so a
# re-run / boot-recovery / post-failure cleanup never errors. Stops DO billing (delete frees the VM).
set -euo pipefail
err() { echo "{\"error\":$(jq -Rn --arg m "$1" '$m')}" >&2; exit 1; }
: "${DO_TOKEN:?DO_TOKEN not set}"
API="https://api.digitalocean.com/v2"
# Token rides in a 0600 temp file (curl -H @file), never argv — argv is world-readable via
# /proc/<pid>/cmdline for the life of every API call. Timeouts keep a stalled DO endpoint from
# eating the whole 120s hook budget (the daemon retries on failure).
HDR="$(mktemp)"; trap 'rm -f "$HDR"' EXIT
printf 'Authorization: Bearer %s\n' "$DO_TOKEN" > "$HDR"
AUTH=(-H @"$HDR" --connect-timeout 10 --max-time 30)
input="$(cat)"
sub_id="$(jq -r '.subscription.id // .instance.subscription_id // empty' <<<"$input")"
id="$(jq -r '.handles.droplet_id // .instance.handles.droplet_id // empty' <<<"$input")"
if [ -z "$id" ] && [ -n "$sub_id" ]; then
  tag="sub:${sub_id}"
  id="$(curl -fsS "${AUTH[@]}" --get --data-urlencode "tag_name=${tag}" "${API}/droplets" | jq -r '.droplets[0].id // empty')"
fi
if [ -n "$id" ]; then
  code="$(curl -sS -o /dev/null -w '%{http_code}' "${AUTH[@]}" -X DELETE "${API}/droplets/${id}")"
  [ "$code" = "204" ] || [ "$code" = "404" ] || err "droplet ${id} delete returned HTTP ${code}"
fi
echo '{"destroyed":true}'
