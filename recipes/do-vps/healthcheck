#!/usr/bin/env bash
# DO VPS healthcheck hook (lnrent recipes/do-vps). SPEC §7.2.
# Reports health via JSON (exit 0 = the check RAN; the daemon reads `healthy`). A transient DO API
# error fails the run (non-zero exit) so the daemon retries rather than declaring the VM dead.
set -euo pipefail
: "${DO_TOKEN:?DO_TOKEN not set}"
API="https://api.digitalocean.com/v2"; AUTH=(-H "Authorization: Bearer ${DO_TOKEN}")
input="$(cat)"
sub_id="$(jq -r '.subscription.id // .instance.subscription_id // empty' <<<"$input")"
id="$(jq -r '.handles.droplet_id // .instance.handles.droplet_id // empty' <<<"$input")"
if [ -z "$id" ] && [ -n "$sub_id" ]; then
  tag="sub:${sub_id}"
  id="$(curl -fsS "${AUTH[@]}" --get --data-urlencode "tag_name=${tag}" "${API}/droplets" | jq -r '.droplets[0].id // empty')"
fi
if [ -z "$id" ]; then echo '{"healthy":false,"reason":"no droplet"}'; exit 0; fi
status="$(curl -fsS "${AUTH[@]}" "${API}/droplets/${id}" | jq -r '.droplet.status // "missing"')"
if [ "$status" = "active" ]; then
  echo '{"healthy":true,"status":"active"}'
else
  jq -n --arg s "$status" '{healthy:false,status:$s}'
fi
