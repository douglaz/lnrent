#!/usr/bin/env bash
# DO VPS `status` management op (request-kind). SPEC §7.4, ADR-0013.
# Input: JSON on stdin. Output: op.result.data JSON on stdout (buyer-facing).
set -euo pipefail
err() { echo "{\"error\":$(jq -Rn --arg m "$1" '$m')}"; exit 1; }
: "${DO_TOKEN:?DO_TOKEN not set}"
API="https://api.digitalocean.com/v2"; AUTH=(-H "Authorization: Bearer ${DO_TOKEN}")
input="$(cat)"
sub_id="$(jq -r '.subscription.id // .instance.subscription_id // empty' <<<"$input")"
id="$(jq -r '.handles.droplet_id // .instance.handles.droplet_id // empty' <<<"$input")"
if [ -z "$id" ] && [ -n "$sub_id" ]; then
  id="$(curl -fsS "${AUTH[@]}" "${API}/droplets?tag_name=sub:${sub_id}" | jq -r '.droplets[0].id // empty')"
fi
[ -n "$id" ] || err "no droplet for this subscription"
d="$(curl -fsS "${AUTH[@]}" "${API}/droplets/${id}")"
status="$(jq -r '.droplet.status' <<<"$d")"
ip="$(jq -r '[.droplet.networks.v4[]? | select(.type=="public") | .ip_address][0] // empty' <<<"$d")"
jq -n --arg s "$status" --arg ip "$ip" '{status:$s, host:$ip, port:22, user:"root"}'
