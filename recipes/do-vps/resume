#!/usr/bin/env bash
# DO VPS resume hook (lnrent recipes/do-vps). SPEC §7.2.
# Powers the droplet back ON after a renewal payment clears a suspension. IDEMPOTENT (no-op if active).
set -euo pipefail
err() { echo "{\"error\":$(jq -Rn --arg m "$1" '$m')}"; exit 1; }
: "${DO_TOKEN:?DO_TOKEN not set}"
API="https://api.digitalocean.com/v2"; AUTH=(-H "Authorization: Bearer ${DO_TOKEN}")
input="$(cat)"
sub_id="$(jq -r '.subscription.id // .instance.subscription_id // empty' <<<"$input")"
id="$(jq -r '.handles.droplet_id // .instance.handles.droplet_id // empty' <<<"$input")"
if [ -z "$id" ] && [ -n "$sub_id" ]; then
  tag="sub:${sub_id}"
  id="$(curl -fsS "${AUTH[@]}" --get --data-urlencode "tag_name=${tag}" "${API}/droplets" | jq -r '.droplets[0].id // empty')"
fi
[ -n "$id" ] || err "no droplet for this subscription to resume"
status="$(curl -fsS "${AUTH[@]}" "${API}/droplets/${id}" | jq -r '.droplet.status')"
if [ "$status" != "active" ]; then
  curl -fsS "${AUTH[@]}" -H "Content-Type: application/json" \
    -X POST "${API}/droplets/${id}/actions" -d '{"type":"power_on"}' >/dev/null
fi
echo '{"resumed":true}'
